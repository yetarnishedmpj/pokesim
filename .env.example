PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins in production
# Example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Leave empty in dev — localhost:5173 is always allowed
CORS_ORIGINS=

# Legacy / optional
MONGO_URI=mongodb://127.0.0.1:27017/pokemon-platform
ENABLE_BULBAPEDIA=0
