{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@pokemon-platform/shared": [
        "./shared/src/index.ts"
      ],
      "@pokemon-platform/engine": [
        "./engine/src/index.ts"
      ],
      "@pokemon-platform/data": [
        "./data/src/index.ts"
      ]
    }
  }
}
